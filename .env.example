# ===================================
# Judo-Arena — пример переменных окружения
# Скопируй этот файл в .env (не коммитить!) и измени значения под свою машину.
# ===================================

# --- БАЗА ДАННЫХ (Postgres из docker-compose) ---
DATABASE_URL="postgresql://judo:judo_dev_password@localhost:5433/judo_arena?schema=public"

# --- REDIS (из docker-compose) ---
REDIS_URL="redis://localhost:6379"

# --- JWT СЕКРЕТЫ ---
# Сгенерируй командой: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="смени_меня_на_длинную_случайную_строку_минимум_64_символа"
JWT_REFRESH_SECRET="другая_длинная_случайная_строка_отличная_от_access"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- API ---
API_PORT=4000
API_HOST="0.0.0.0"
NODE_ENV="development"

# --- FRONTEND (web) ---
VITE_API_URL="http://localhost:4000"
VITE_WS_URL="ws://localhost:4000"

# --- CORS (фронт) ---
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:5173"

# --- EMAIL (Mailpit в dev) ---
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Judo-Arena <noreply@judo-arena.kz>"

# --- ФАЙЛЫ (локально в dev) ---
UPLOADS_DIR="./uploads"

# --- BCRYPT ---
BCRYPT_ROUNDS=12

# --- RATE LIMITING ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"

# --- МОНИТОРИНГ (Sentry — опционально) ---
# Получить DSN: https://sentry.io → New Project → Node.js (backend) / React (frontend)
# Free tier: 5 000 ошибок/месяц — достаточно для старта.
#
# Шаги:
#   1. Зарегистрируйся на sentry.io (бесплатно)
#   2. Создай два проекта: Node.js (для API) и React (для Web)
#   3. Скопируй DSN каждого проекта ниже
#   4. Для загрузки source maps добавь SENTRY_AUTH_TOKEN (Settings → Auth Tokens)
SENTRY_DSN=
VITE_SENTRY_DSN=
# Source maps upload (только для production build в CI)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=judo-arena-web
# Версия релиза (обычно git SHA или semver, проставляется в CI)
VITE_RELEASE=

# --- ХРАНИЛИЩЕ ФАЙЛОВ (S3 / R2 / MinIO) ---
# Если не задан S3_BUCKET — файлы сохраняются локально в UPLOADS_DIR
# Для Cloudflare R2: S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=
S3_ENDPOINT=
S3_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- БЭКАП ---
# Если задан — backup.sh будет загружать дамп в S3-совместимое хранилище
BACKUP_S3_BUCKET=

# --- ДЕПЛОЙ ---
# Render webhook (триггерится из GitHub Actions при пуше в main)
# RENDER_DEPLOY_HOOK_URL=
# Cloudflare Pages (заполнять в GitHub Actions secrets, не здесь)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
