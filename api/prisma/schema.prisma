// Judo-Arena — Prisma schema (15 таблиц, ТЗ v2.1)
// Документация: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ATHLETE
  COACH
  ADMIN
  // JUDGE не хранится здесь — у судьи временная сессия без аккаунта
}

enum UserDocumentType {
  BIRTH_CERTIFICATE
  STUDY_CERTIFICATE
  COACH_ID
}

enum ClubRole {
  OWNER
  COACH
}

enum Gender {
  MALE
  FEMALE
}

enum Locale {
  ru
  kk
  en
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BracketFormat {
  SE_IJF // Single Elimination с IJF Repechage
  ROUND_ROBIN // Круговая
  MIXED // Группы + плей-офф (опционально)
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
}

enum WeighInStatus {
  PENDING
  PASSED
  FAILED_WEIGHT
  FAILED_DOCUMENTS
  ABSENT
  WITHDRAWN
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MatchEventType {
  HAJIME // Начало
  MATE // Пауза
  SORE_MADE // Конец матча
  IPPON
  WAZA_ARI
  YUKO // Опционально (старые правила)
  SHIDO
  HANSOKU_MAKE
  GOLDEN_SCORE // Переход в Golden Score
  REPLAY // Видеоповтор/пересмотр
  END
  OSAEKOMI // Начало удержания
  TOKETA // Конец удержания
}

enum MatchSide {
  RED // Красный (или синий — в дзюдо обычно синий)
  BLUE
  WHITE // Белый
  SYSTEM
}

// ============================================================
// USERS / CLUBS
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  role            UserRole
  name            String // Имя (кириллица или родной)
  surname         String // Фамилия
  nameLatin       String? // Имя латиницей (для международных протоколов)
  surnameLatin    String?
  dateOfBirth     DateTime?
  gender          Gender?
  weightKg        Float?
  beltRank        String? // 6 kyu ... 10 dan
  preferredLocale Locale    @default(kk)
  avatarUrl       String?
  phone           String?
  city            String?
  education       String?
  coachCategory   String?
  coachExperienceYears Int?
  coachTitle      String?
  isActive        Boolean   @default(true)

  // Email verification
  emailVerified           Boolean   @default(false)
  emailVerificationToken  String? // one-time token (expires in 24h)
  emailVerificationSentAt DateTime? // when last token was sent (rate-limit)

  // 2FA (TOTP — Google Authenticator / Authy)
  totpSecret  String? // зашифрованный base32-секрет; null = 2FA не настроен
  totpEnabled Boolean @default(false)

  clubId   String?
  club     Club?     @relation(fields: [clubId], references: [id])
  clubRole ClubRole?

  // Связи
  createdClubs          Club[]                 @relation("ClubCreator")
  createdTournaments    Tournament[]           @relation("TournamentCreator")
  applicationEntries    ApplicationEntry[]
  weighedEntries        ApplicationEntry[]     @relation("WeighInReviewer")
  clubJoinRequests      ClubJoinRequest[]
  coachClubJoinRequests CoachClubJoinRequest[] @relation("CoachClubJoinRequests")
  bluematches           Match[]                @relation("BlueAthlete")
  redmatches            Match[]                @relation("RedAthlete")
  wonMatches            Match[]                @relation("WinnerAthlete")
  ratingEntries         RatingEntry[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  tatamiSessions        TatamiSession[]        @relation("TatamiSessionCreator")
  documents             UserDocument[]
  pushSubscriptions     PushSubscription[]

  deletedAt DateTime? // null = активный; задан = мягко удалён

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([role])
  @@index([role, isActive])
  @@index([emailVerificationToken]) // быстрый поиск при верификации
  @@index([deletedAt])
}

model UserDocument {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         UserDocumentType
  url          String
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  uploadedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

model Club {
  id            String  @id @default(cuid())
  name          Json // { ru, kk, en }
  shortName     String?
  city          String
  country       String   @default("KZ")
  address       String?
  phone         String?
  email         String?
  instagram     String?
  logoUrl       String?
  coverUrl      String?
  galleryUrls   String[] @default([])
  description   Json?    // { ru, kk, en }
  isActive      Boolean  @default(true)
  isBlocked     Boolean  @default(false)
  blockedReason String?

  createdById String?
  createdBy   User?   @relation("ClubCreator", fields: [createdById], references: [id], onDelete: SetNull)

  members           User[]
  groups            ClubGroup[]
  applications      Application[]
  joinRequests      ClubJoinRequest[]
  coachJoinRequests CoachClubJoinRequest[]

  deletedAt DateTime? // null = активный; задан = мягко удалён

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([isActive, isBlocked])
  @@index([deletedAt])
}

model ClubGroup {
  id     String @id @default(cuid())
  clubId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name   String // "Дети", "Юниоры", "Взрослые"
  ageMin Int
  ageMax Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
}

// ============================================================
// TOURNAMENTS / CATEGORIES
// ============================================================

model Tournament {
  id                  String           @id @default(cuid())
  name                Json // { ru, kk, en }
  description         Json?
  location            String
  city                String
  startDate           DateTime
  endDate             DateTime
  applicationDeadline DateTime?
  mapUrl              String?
  weighInLocation     String?
  weighInStart        DateTime?
  weighInEnd          DateTime?
  status              TournamentStatus @default(DRAFT)
  tatamiCount         Int              @default(1)
  primaryLocale       Locale           @default(kk)
  posterUrl           String?
  galleryUrls         Json? // string[] — public tournament gallery, max 6 images
  regulationUrl       String?
  regulationFileName  String?
  entryFeeKzt         Int              @default(0)
  kaspiPaymentUrl     String?
  youtubeUrls         Json? // string[] — one URL per tatami (index 0 = tatami 1)
  isFeatured          Boolean          @default(false)
  isArchived          Boolean          @default(false)

  createdById String?
  createdBy   User?   @relation("TournamentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  categories     Category[]
  applications   Application[]
  brackets       Bracket[]
  matches        Match[]
  ratingEntries  RatingEntry[]
  tatamiSessions TatamiSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startDate])
  @@index([status, isArchived, startDate])
  @@index([city, status])
  @@index([createdById])
}

model Category {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  name             Json? // Опциональное название категории
  matchDate        DateTime? // День проведения матчей категории
  gender           Gender
  ageMin           Int
  ageMax           Int
  weightMin        Float
  weightMax        Float
  matchDurationSec Int           @default(240) // 4 минуты по умолчанию
  goldenScoreSec   Int           @default(0) // 0 = без лимита
  format           BracketFormat @default(SE_IJF)
  allowYuko        Boolean       @default(true) // Юко оценка (по умолчанию включена)

  applicationEntries ApplicationEntry[]
  brackets           Bracket[]
  ratingEntries      RatingEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([tournamentId, gender, ageMin, ageMax])
}

// ============================================================
// APPLICATIONS
// ============================================================

model Application {
  id               String            @id @default(cuid())
  tournamentId     String
  tournament       Tournament        @relation(fields: [tournamentId], references: [id])
  clubId           String
  club             Club              @relation(fields: [clubId], references: [id])
  status           ApplicationStatus @default(DRAFT)
  notes            String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  reviewerNotes    String?
  paymentStatus    PaymentStatus     @default(NOT_REQUIRED)
  paymentAmountKzt Int               @default(0)
  paymentProvider  String?
  paymentReference String?
  paymentUrl       String?
  paidAt           DateTime?

  entries ApplicationEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, clubId])
  @@index([status])
  @@index([paymentStatus])
  @@index([paymentReference])
  @@index([tournamentId, status])
  @@index([clubId, status])
}

model ApplicationEntry {
  id             String        @id @default(cuid())
  applicationId  String
  application    Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  athleteId      String
  athlete        User          @relation(fields: [athleteId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  weighInStatus  WeighInStatus @default(PENDING)
  actualWeightKg Float?
  weighInNotes   String?
  weighedAt      DateTime?
  weighedById    String?
  weighedBy      User?         @relation("WeighInReviewer", fields: [weighedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicationId, athleteId, categoryId])
  @@index([categoryId])
  @@index([weighInStatus])
  @@index([weighedById])
  @@index([athleteId])
  @@index([categoryId, weighInStatus])
}

// ============================================================
// BRACKETS / MATCHES
// ============================================================

model Bracket {
  id           String        @id @default(cuid())
  tournamentId String
  tournament   Tournament    @relation(fields: [tournamentId], references: [id])
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  format       BracketFormat
  size         Int // Размер сетки (4/8/16/32/64) или N для round-robin
  metadata     Json? // MIXED: { groups: [{ label, athleteIds }] }

  generatedAt DateTime @default(now())

  matches Match[]

  @@unique([tournamentId, categoryId])
  @@index([tournamentId])
  @@index([categoryId])
}

model Match {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  bracketId    String
  bracket      Bracket    @relation(fields: [bracketId], references: [id], onDelete: Cascade)

  round          Int // Номер раунда: 1, 2, 3... для SE; для RR — "тур"
  position       Int // Позиция матча в раунде (от 0)
  bracketSection String? // "main" | "repechage" | "bronze1" | "bronze2" | "final"

  redAthleteId  String?
  redAthlete    User?   @relation("RedAthlete", fields: [redAthleteId], references: [id])
  blueAthleteId String?
  blueAthlete   User?   @relation("BlueAthlete", fields: [blueAthleteId], references: [id])

  tatamiNumber  Int?
  queuePosition Int?
  status        MatchStatus @default(PENDING)

  winnerId      String?
  winner        User?   @relation("WinnerAthlete", fields: [winnerId], references: [id])
  scoreSnapshot Json? // { red:{ippon,wazaari,yuko,shido}, blue:{...}, totalTimeSec }

  isGoldenScore        Boolean   @default(false)
  goldenScoreStartedAt DateTime? // точное время входа в golden score — для корректного восстановления таймера
  isReplay             Boolean   @default(false)
  replayReason         String?

  startedAt  DateTime?
  finishedAt DateTime?

  version Int @default(0) // Optimistic locking

  judgeSessions JudgeSession[]
  events        MatchEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([bracketId, round, position])
  @@index([status])
  @@index([tatamiNumber])
  @@index([tatamiNumber, queuePosition])
  @@index([tournamentId, status])
  @@index([tournamentId, tatamiNumber, queuePosition])
  @@index([redAthleteId])
  @@index([blueAthleteId])
  @@index([winnerId])
}

model MatchEvent {
  id                  String         @id @default(cuid())
  matchId             String
  match               Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type                MatchEventType
  side                MatchSide? // Кому начислили (если применимо)
  actorJudgeSessionId String? // Какая судейская сессия зафиксировала
  scoreSnapshot       Json? // Состояние счёта после события
  meta                Json?

  occurredAt DateTime @default(now())

  @@index([matchId, occurredAt])
  @@index([matchId, type]) // undoLastScoreEvent фильтрует по matchId + type IN [...]
}

model JudgeSession {
  id        String    @id @default(cuid())
  matchId   String
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  token     String    @unique
  judgeName String? // Имя судьи (опционально, без аккаунта)
  expiresAt DateTime
  usedAt    DateTime?
  isRevoked Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([expiresAt, isRevoked])
}

/// Сессия судьи на целый татами (один токен = все матчи татами за день).
model TatamiSession {
  id           String     @id @default(cuid())
  token        String     @unique
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tatamiNumber Int
  judgeName    String?
  createdById  String?
  createdBy    User?      @relation("TatamiSessionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt    DateTime // default: +14 часов
  isRevoked    Boolean    @default(false)

  createdAt DateTime @default(now())

  @@index([tournamentId, tatamiNumber])
  @@index([expiresAt, isRevoked])
}

// ============================================================
// RATING / NOTIFICATIONS / AUDIT
// ============================================================

model RatingEntry {
  id           String     @id @default(cuid())
  athleteId    String
  athlete      User       @relation(fields: [athleteId], references: [id])
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  place        Int // 1, 2, 3, 3, 5, 5, 7, 7
  points       Float // Поддерживает бонусы (десятичные)

  awardedAt DateTime @default(now())

  @@unique([athleteId, tournamentId, categoryId])
  @@index([athleteId])
  @@index([tournamentId])
  @@index([categoryId])
  @@index([points])
  @@index([athleteId, points]) // Leaderboard groupBy athleteId с суммой points
}

model Notification {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     String // "application_approved", "match_scheduled", и т.д.
  titleKey String // i18n-ключ
  bodyKey  String
  payload  Json?
  read     Boolean @default(false)
  locale   Locale  @default(kk)

  createdAt DateTime @default(now())

  @@index([userId, read])
}

model AuditLog {
  id           String  @id @default(cuid())
  actorUserId  String?
  actor        User?   @relation(fields: [actorUserId], references: [id])
  action       String // "match.override", "bracket.regenerate", и т.д.
  targetEntity String // "Match" | "Bracket" | ...
  targetId     String
  before       Json?
  after        Json?
  metadata     Json?
  ipAddress    String?
  userAgent    String?

  createdAt DateTime @default(now())

  @@index([targetEntity, targetId])
  @@index([actorUserId, createdAt])
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

/// Web Push подписки пользователей (VAPID)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String // публичный ключ браузера
  auth      String // auth secret
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ClubJoinRequest {
  id        String            @id @default(cuid())
  athleteId String
  athlete   User              @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  clubId    String
  club      Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([athleteId, clubId])
  @@index([clubId, status])
}

model CoachClubJoinRequest {
  id        String            @id @default(cuid())
  coachId   String
  coach     User              @relation("CoachClubJoinRequests", fields: [coachId], references: [id], onDelete: Cascade)
  clubId    String
  club      Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([coachId, clubId])
  @@index([clubId, status])
  @@index([coachId, status])
}
